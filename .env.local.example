# Anthropic API key — used to bill Claude directly to your Anthropic account.
# Get one at: https://console.anthropic.com/settings/keys
# Set this:
#   - locally: copy this file to .env.local and fill in the value
#   - on Vercel: Project Settings → Environment Variables → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# Google — powers the "Tracked Keywords" (Search Console) and "GA4 Metrics"
# (Google Analytics 4) panels on SEO projects.
# Paste the FULL JSON key file of a Google Cloud service account (one line).
GOOGLE_SERVICE_ACCOUNT_JSON=

# Domain-wide delegation: the Workspace user the service account impersonates.
# This user must have access to every client's Search Console + GA4 property.
# With this set, no per-client access grant is needed.
GOOGLE_IMPERSONATE_SUBJECT=seo@wonder-ads.com

# Google AI Studio key — powers GMB Posts image generation via Gemini
# 2.5 Flash Image (uses uploaded client files + Drive links as reference
# so generated images stay on-brand). Free tier exists.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Superadmin password gating the /changelog page. Defaults to "superadmin"
# when unset — override it in Vercel for anything beyond local dev.
CHANGELOG_PASSWORD=superadmin
