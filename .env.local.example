# Anthropic API key — used to bill Claude directly to your Anthropic account.
# Get one at: https://console.anthropic.com/settings/keys
# Set this:
#   - locally: copy this file to .env.local and fill in the value
#   - on Vercel: Project Settings → Environment Variables → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# Google Search Console — powers the "Tracked Keywords" panel on SEO projects.
# Paste the FULL JSON key file of a Google Cloud service account (one line).
GOOGLE_SERVICE_ACCOUNT_JSON=

# Domain-wide delegation: the Workspace user the service account impersonates.
# This user must own/have access to every client's Search Console property.
# With this set, no per-client access grant is needed in Search Console.
GOOGLE_IMPERSONATE_SUBJECT=seo@wonder-ads.com
